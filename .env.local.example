# ─── Supabase ───
# Find in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database ───
# POOLED (port 6543) — used at runtime by the app for all normal queries
# Find in: Supabase Dashboard → Settings → Database → Connection string → URI (connection pooler)
DATABASE_URL=postgresql://postgres.YOUR-REF:password@aws-0-REGION.pooler.supabase.com:6543/postgres

# DIRECT (port 5432) — used ONLY by drizzle-kit for migrations
# Find in: Supabase Dashboard → Settings → Database → Connection string → URI (direct connection)
DIRECT_URL=postgresql://postgres.YOUR-REF:password@aws-0-REGION.pooler.supabase.com:5432/postgres
